<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Releases</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            background: #0f0f13;
            color: #e8e8f0;
            min-height: 100vh;
        }

        header {
            background: #18182a;
            border-bottom: 1px solid #2a2a40;
            padding: 16px 24px;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        header h1 { font-size: 1.2rem; font-weight: 700; }
        #resultCount { margin-left: auto; font-size: 0.8rem; color: #777; }

        .filters {
            background: #18182a;
            border-bottom: 1px solid #2a2a40;
            padding: 12px 24px;
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 20px;
        }
        .filter-label { font-size: 0.8rem; color: #888; white-space: nowrap; }
        .filter-group { display: flex; align-items: center; gap: 8px; }

        #ratingSlider {
            -webkit-appearance: none;
            width: 130px; height: 4px;
            border-radius: 2px;
            background: #3a3a5a;
            outline: none; cursor: pointer;
        }
        #ratingSlider::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 15px; height: 15px;
            border-radius: 50%;
            background: #7c6af7;
            cursor: pointer;
        }
        #ratingVal {
            background: #7c6af7; color: #fff;
            font-size: 0.75rem; font-weight: 700;
            padding: 2px 7px; border-radius: 10px;
            min-width: 30px; text-align: center;
        }

        .source-chips { display: flex; flex-wrap: wrap; gap: 7px; }
        .chip-wrap input { display: none; }
        .chip-wrap label {
            display: inline-flex; align-items: center; gap: 5px;
            padding: 4px 11px; border-radius: 20px;
            font-size: 0.78rem; font-weight: 500;
            border: 1.5px solid #333350; color: #777;
            cursor: pointer; transition: all .15s; user-select: none;
        }
        .chip-wrap input:checked + label {
            border-color: var(--c); color: var(--c);
            background: color-mix(in srgb, var(--c) 12%, transparent);
        }
        .chip-wrap label:hover { border-color: var(--c); color: var(--c); }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(155px, 1fr));
            gap: 14px;
            padding: 20px 24px;
            max-width: 1400px;
            margin: 0 auto;
        }

        .card {
            background: #18182a;
            border-radius: 9px; overflow: hidden;
            border: 1px solid #2a2a40;
            display: flex; flex-direction: column;
            transition: transform .15s, box-shadow .15s;
            cursor: default;
        }
        .card:hover { transform: translateY(-3px); box-shadow: 0 8px 22px rgba(0,0,0,.55); }

        .card-poster-wrap {
            position: relative; width: 100%; aspect-ratio: 2/3;
            display: block; text-decoration: none;
        }
        a.card-poster-wrap { cursor: pointer; }
        .card-poster {
            width: 100%; height: 100%;
            object-fit: cover; background: #252538;
            display: block;
        }
        .card-placeholder {
            width: 100%; height: 100%;
            background: #252538; display: flex;
            align-items: center; justify-content: center;
            font-size: 2.2rem;
        }
        .info-link {
            position: absolute; top: 7px; right: 7px;
            width: 22px; height: 22px; border-radius: 50%;
            background: rgba(0,0,0,.65);
            backdrop-filter: blur(4px);
            color: #aaa;
            font-size: 0.72rem; font-weight: 700;
            display: flex; align-items: center; justify-content: center;
            text-decoration: none;
            border: 1px solid rgba(255,255,255,.15);
            transition: background .15s, color .15s;
        }
        .info-link:hover { background: #7c6af7; color: #fff; }

        .service-badge {
            position: absolute; bottom: 7px; left: 7px;
            font-size: 0.62rem; font-weight: 700;
            padding: 2px 7px; border-radius: 4px;
            background: rgba(0,0,0,.72);
            border-left: 3px solid var(--sc);
            color: var(--sc);
            letter-spacing: .03em;
            backdrop-filter: blur(4px);
            max-width: calc(100% - 14px);
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        }

        .card-body { padding: 9px; flex: 1; display: flex; flex-direction: column; gap: 5px; }
        .card-title {
            font-size: 0.8rem; font-weight: 600; line-height: 1.3;
            display: -webkit-box; -webkit-line-clamp: 2;
            -webkit-box-orient: vertical; overflow: hidden;
        }

        .card-row { display: flex; align-items: center; gap: 5px; flex-wrap: wrap; margin-top: auto; padding-top: 5px; }
        .card-year { font-size: 0.7rem; color: #888; }
        .badge {
            font-size: 0.62rem; font-weight: 700; padding: 2px 5px;
            border-radius: 3px; text-transform: uppercase; letter-spacing: .04em;
        }
        .b-movie { background: #1e2e48; color: #6aadff; }
        .b-tv    { background: #1e3828; color: #6aee9a; }

        .source-dot {
            width: 7px; height: 7px; border-radius: 50%;
            display: inline-block; flex-shrink: 0;
        }

        .rating {
            margin-left: auto; font-size: 0.78rem; font-weight: 700;
            color: #f5c518; display: flex; align-items: center; gap: 2px;
        }
        .rating::before { content: "★"; }
        .rating.critic { color: #f28b00; }
        .rating.critic::before { content: ""; }
        .rating-src { font-size: 0.6rem; font-weight: 400; margin-left: 1px; opacity: .8; }
        .rating.no-rating { color: #444; }
        .rating.no-rating::before { content: ""; }

        .state {
            display: flex; flex-direction: column; align-items: center;
            justify-content: center; gap: 10px;
            min-height: 300px; color: #555; font-size: 0.88rem;
        }
        .spinner {
            width: 34px; height: 34px;
            border: 3px solid #2a2a40; border-top-color: #7c6af7;
            border-radius: 50%; animation: spin .7s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
    </style>
</head>
<body>

<header>
    <h1>&#127916; New Releases</h1>
    <span id="resultCount"></span>
</header>

<div class="filters">
    <div class="filter-group">
        <span class="filter-label">Min rating</span>
        <input type="range" id="ratingSlider" min="0" max="10" step="0.5" value="7">
        <span id="ratingVal">7.0</span>
    </div>
    <div class="filter-group">
        <span class="filter-label">Services</span>
        <div class="source-chips">
            <span class="chip-wrap">
                <input type="checkbox" id="s203" data-name="Netflix"    checked>
                <label for="s203" style="--c:#e50914">Netflix</label>
            </span>
            <span class="chip-wrap">
                <input type="checkbox" id="s372" data-name="Disney+"    checked>
                <label for="s372" style="--c:#0063e5">Disney+</label>
            </span>
            <span class="chip-wrap">
                <input type="checkbox" id="s26"  data-name="Prime Video" checked>
                <label for="s26"  style="--c:#00a8e1">Amazon</label>
            </span>
            <span class="chip-wrap">
                <input type="checkbox" id="s387" data-name="MAX"        checked>
                <label for="s387" style="--c:#b5179e">HBO Max</label>
            </span>
        </div>
    </div>
    <div class="filter-group">
        <span class="filter-label">Released within</span>
        <input type="range" id="monthsSlider" min="0" max="6" step="1" value="1">
        <span id="monthsVal">1 month</span>
    </div>
    <div class="filter-group">
        <input type="checkbox" id="showUnrated">
        <label for="showUnrated" class="filter-label" style="cursor:pointer">Show unrated</label>
    </div>
</div>

<div id="content">
    <div class="state"><div class="spinner"></div><span>Loading releases...</span></div>
</div>

#[[
<script>
    const SOURCE_COLORS = {
        'Netflix':     '#e50914',
        'Disney+':     '#0063e5',
        'Prime Video': '#00a8e1',
        'MAX':         '#b5179e'
    };

    const content      = document.getElementById('content');
    const ratingSlider = document.getElementById('ratingSlider');
    const ratingVal    = document.getElementById('ratingVal');
    const monthsSlider = document.getElementById('monthsSlider');
    const monthsVal    = document.getElementById('monthsVal');
    const resultCount  = document.getElementById('resultCount');

    let allTitles = [];

    /* ── Load once ── */
    async function load() {
        try {
            const res = await fetch('/api/watchmode/releases');
            const data = await res.json();
            allTitles = data.titles || [];
            render();
        } catch (e) {
            content.innerHTML = '<div class="state"><span>&#9888; Failed to load. Try refreshing.</span></div>';
        }
    }

    /* ── Filter + render ── */
    function render() {
        const minRating  = parseFloat(ratingSlider.value);
        const activeSrcs = new Set(
            [...document.querySelectorAll('.chip-wrap input:checked')]
                .map(el => el.dataset.name)
        );

        const showUnrated = document.getElementById('showUnrated').checked;
        const months = parseInt(monthsSlider.value);
        const cutoff = new Date();
        cutoff.setMonth(cutoff.getMonth() - months);
        const cutoffStr = cutoff.toISOString().slice(0, 10);

        const visible = allTitles.filter(t => {
            const sources = t.sources || [];
            if (!sources.some(s => activeSrcs.has(s))) return false;
            if ((t.source_release_date || '') < cutoffStr) return false;
            if (t.user_rating == null) return showUnrated;
            return t.user_rating >= minRating;
        });

        resultCount.textContent = visible.length + ' title' + (visible.length !== 1 ? 's' : '');

        if (visible.length === 0) {
            content.innerHTML = '<div class="state"><span>No titles match the current filters.</span></div>';
            return;
        }

        const grid = document.createElement('div');
        grid.className = 'grid';

        visible.forEach(t => {
            const isTV = t.type && t.type.startsWith('tv');
            const card = document.createElement('div');
            card.className = 'card';

            const primarySource = (t.sources && t.sources.length) ? t.sources[0] : '';
            const srcColor = SOURCE_COLORS[primarySource] || '#888';
            const badge = primarySource
                ? '<span class="service-badge" style="--sc:' + srcColor + '">' + esc(primarySource) + '</span>'
                : '';
            const posterInner = t.poster_url
                ? '<img class="card-poster" src="' + esc(t.poster_url) + '" alt="" loading="lazy">'
                : '<div class="card-placeholder">' + (isTV ? '📺' : '🎬') + '</div>';
            const imdbHref = t.imdb_id ? 'https://www.imdb.com/title/' + esc(t.imdb_id) + '/' : '';
            const infoLink = '<a class="info-link" href="/watchmode/title/' + t.id + '" target="_blank" rel="noopener" title="Raw data">i</a>';
            const poster = imdbHref
                ? '<a class="card-poster-wrap" href="' + imdbHref + '" target="_blank" rel="noopener">' + posterInner + badge + infoLink + '</a>'
                : '<div class="card-poster-wrap">' + posterInner + badge + infoLink + '</div>';

            const year = t.year || '';
            let ratingDisplay;
            if (t.user_rating != null) {
                ratingDisplay = '<span class="rating">' + t.user_rating.toFixed(1) + '</span>';
            } else if (t.critic_score != null) {
                ratingDisplay = '<span class="rating critic">' + t.critic_score + '<span class="rating-src">RT</span></span>';
            } else {
                ratingDisplay = '<span class="rating no-rating">&mdash;</span>';
            }

            card.innerHTML = poster +
                '<div class="card-body">' +
                  '<div class="card-title">' + esc(t.title) + '</div>' +
                  '<div class="card-row">' +
                    '<span class="card-year">' + year + '</span>' +
                    '<span class="badge ' + (isTV ? 'b-tv' : 'b-movie') + '">' + (isTV ? 'TV' : 'Film') + '</span>' +
                    ratingDisplay +
                  '</div>' +
                '</div>';

            grid.appendChild(card);
        });

        content.innerHTML = '';
        content.appendChild(grid);
    }

    function esc(s) {
        return String(s)
            .replace(/&/g, '&amp;').replace(/</g, '&lt;')
            .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    ratingSlider.addEventListener('input', () => {
        ratingVal.textContent = parseFloat(ratingSlider.value).toFixed(1);
        render();
    });

    monthsSlider.addEventListener('input', () => {
        const m = parseInt(monthsSlider.value);
        monthsVal.textContent = m === 0 ? 'Today' : m === 1 ? '1 month' : m + ' months';
        render();
    });

    document.querySelectorAll('.chip-wrap input').forEach(cb => {
        cb.addEventListener('change', render);
    });
    document.getElementById('showUnrated').addEventListener('change', render);

    load();
</script>
