<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Streaming News</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            background: #0d0d14;
            color: #e0e0ee;
            min-height: 100vh;
        }

        header {
            background: #14141f;
            border-bottom: 1px solid #222235;
            padding: 16px 24px;
            display: flex;
            align-items: center;
            gap: 12px;
            position: sticky;
            top: 0;
            z-index: 10;
        }
        header h1 { font-size: 1.2rem; font-weight: 700; letter-spacing: -.02em; }

        .live-dot {
            width: 10px; height: 10px; border-radius: 50%;
            background: #ff3b30;
            animation: pulse 1.4s ease-in-out infinite;
            flex-shrink: 0;
        }
        @keyframes pulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50%       { opacity: .5; transform: scale(.75); }
        }

        #status {
            margin-left: auto;
            font-size: 0.75rem;
            color: #555;
        }
        #status.connected { color: #3cb95e; }
        #status.error     { color: #ff5555; }

        .source-bar {
            background: #14141f;
            border-bottom: 1px solid #222235;
            padding: 10px 24px;
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            align-items: center;
        }
        .src-label { font-size: 0.75rem; color: #666; margin-right: 4px; }

        .chip-wrap input { display: none; }
        .chip-wrap label {
            display: inline-block;
            padding: 3px 12px; border-radius: 20px;
            font-size: 0.75rem; font-weight: 600;
            border: 1.5px solid #2a2a3c; color: #666;
            cursor: pointer; transition: all .15s; user-select: none;
        }
        .chip-wrap input:checked + label {
            border-color: var(--c); color: var(--c);
            background: color-mix(in srgb, var(--c) 12%, transparent);
        }
        .chip-wrap label:hover { border-color: var(--c); color: var(--c); }

        #feed {
            max-width: 780px;
            margin: 24px auto;
            padding: 0 16px;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .article {
            background: #14141f;
            border: 1px solid #222235;
            border-radius: 10px;
            padding: 14px 16px;
            display: flex;
            flex-direction: column;
            gap: 6px;
            animation: slideIn .35s ease;
            cursor: pointer;
            text-decoration: none;
            color: inherit;
            transition: border-color .15s, transform .15s;
        }
        .article:hover {
            border-color: #3a3a5c;
            transform: translateX(3px);
        }
        @keyframes slideIn {
            from { opacity: 0; transform: translateY(-12px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .article-top {
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .source-badge {
            font-size: 0.65rem; font-weight: 700;
            padding: 2px 8px; border-radius: 4px;
            text-transform: uppercase; letter-spacing: .05em;
            flex-shrink: 0;
        }
        .article-date {
            font-size: 0.68rem;
            color: #555;
            margin-left: auto;
            flex-shrink: 0;
        }

        .article-title {
            font-size: 0.95rem;
            font-weight: 600;
            line-height: 1.4;
        }
        .article-desc {
            font-size: 0.8rem;
            color: #888;
            line-height: 1.5;
        }

        .state {
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            gap: 12px; min-height: 300px;
            color: #444; font-size: 0.88rem;
            text-align: center;
        }
        .spinner {
            width: 34px; height: 34px;
            border: 3px solid #222235; border-top-color: #6c63ff;
            border-radius: 50%; animation: spin .7s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }

        .new-banner {
            text-align: center;
            font-size: 0.75rem; font-weight: 600;
            color: #6c63ff;
            padding: 6px;
            cursor: pointer;
            letter-spacing: .04em;
        }
        .new-banner:hover { text-decoration: underline; }
    </style>
</head>
<body>

<header>
    <div class="live-dot"></div>
    <h1>Streaming News</h1>
    <span id="status">Connecting…</span>
</header>

<div class="source-bar">
    <span class="src-label">Sources</span>
    <span class="chip-wrap">
        <input type="checkbox" id="src-bbc" data-source="BBC News" checked>
        <label for="src-bbc" style="--c:#e50914">BBC News</label>
    </span>
    <span class="chip-wrap">
        <input type="checkbox" id="src-guardian" data-source="The Guardian" checked>
        <label for="src-guardian" style="--c:#052962">The Guardian</label>
    </span>
    <span class="chip-wrap">
        <input type="checkbox" id="src-npr" data-source="NPR News" checked>
        <label for="src-npr" style="--c:#1e6d9c">NPR News</label>
    </span>
</div>

<div id="feed">
    <div class="state" id="loading-state">
        <div class="spinner"></div>
        <span>Connecting to live feed…</span>
    </div>
</div>

