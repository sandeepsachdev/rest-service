<script>
    const SOURCE_COLORS = {
        'BBC News':    { bg: '#1a0505', border: '#e50914', text: '#e50914' },
        'The Guardian':{ bg: '#050d1a', border: '#052962', text: '#4a90d9' },
        'NPR News':    { bg: '#051018', border: '#1e6d9c', text: '#4ab0d9' }
    };

    const feed         = document.getElementById('feed');
    const statusEl     = document.getElementById('status');
    const loadingState = document.getElementById('loading-state');

    let articleCount = 0;
    let pendingQueue = [];   // articles buffered while user scrolled away
    let isAtTop = true;

    function activeSourceSet() {
        return new Set(
            [...document.querySelectorAll('.chip-wrap input:checked')]
                .map(el => el.dataset.source)
        );
    }

    function formatDate(raw) {
        if (!raw) return '';
        try {
            return new Date(raw).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        } catch { return ''; }
    }

    function esc(s) {
        return String(s)
            .replace(/&/g, '&amp;').replace(/</g, '&lt;')
            .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    function buildCard(article) {
        const colors = SOURCE_COLORS[article.source] || { bg: '#141420', border: '#444', text: '#aaa' };
        const a = document.createElement('a');
        a.className = 'article';
        a.href = article.link;
        a.target = '_blank';
        a.rel = 'noopener noreferrer';
        a.dataset.source = article.source;
        a.style.borderLeftColor = colors.border;
        a.style.borderLeftWidth = '3px';

        a.innerHTML =
            '<div class="article-top">' +
              '<span class="source-badge" style="background:' + colors.bg + ';color:' + colors.text + ';border:1px solid ' + colors.border + '">' + esc(article.source) + '</span>' +
              '<span class="article-date">' + esc(formatDate(article.pubDate)) + '</span>' +
            '</div>' +
            '<div class="article-title">' + esc(article.title) + '</div>' +
            (article.desc ? '<div class="article-desc">' + esc(article.desc) + '</div>' : '');

        return a;
    }

    function insertArticle(article, prepend) {
        const activeSources = activeSourceSet();
        if (!activeSources.has(article.source)) return;

        if (loadingState && loadingState.parentNode === feed) {
            feed.removeChild(loadingState);
        }

        const card = buildCard(article);
        if (prepend) {
            // If user is scrolled down, queue instead of inserting
            if (!isAtTop && articleCount > 0) {
                pendingQueue.push(article);
                updatePendingBanner();
                return;
            }
            feed.insertBefore(card, feed.firstChild);
        } else {
            feed.appendChild(card);
        }
        articleCount++;
    }

    function updatePendingBanner() {
        let banner = document.getElementById('pending-banner');
        if (!banner) {
            banner = document.createElement('div');
            banner.id = 'pending-banner';
            banner.className = 'new-banner';
            banner.addEventListener('click', flushPending);
            feed.insertBefore(banner, feed.firstChild);
        }
        banner.textContent = '▲ ' + pendingQueue.length + ' new article' + (pendingQueue.length !== 1 ? 's' : '') + ' — click to show';
    }

    function flushPending() {
        const banner = document.getElementById('pending-banner');
        if (banner) feed.removeChild(banner);
        const toFlush = pendingQueue.splice(0);
        toFlush.reverse().forEach(a => {
            const card = buildCard(a);
            feed.insertBefore(card, feed.firstChild);
            articleCount++;
        });
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // Track scroll position
    window.addEventListener('scroll', () => {
        isAtTop = window.scrollY < 120;
        if (isAtTop && pendingQueue.length > 0) flushPending();
    });

    // Source filter toggles
    document.querySelectorAll('.chip-wrap input').forEach(cb => {
        cb.addEventListener('change', () => {
            const activeSources = activeSourceSet();
            document.querySelectorAll('.article').forEach(el => {
                el.style.display = activeSources.has(el.dataset.source) ? '' : 'none';
            });
        });
    });

    // SSE connection
    function connect() {
        const es = new EventSource('/api/streaming-news/events');

        es.addEventListener('article', e => {
            try {
                const article = JSON.parse(e.data);
                const isInitial = articleCount === 0;
                insertArticle(article, !isInitial);
            } catch {}
        });

        es.onopen = () => {
            statusEl.textContent = 'Live';
            statusEl.className = 'connected';
        };

        es.onerror = () => {
            statusEl.textContent = 'Reconnecting…';
            statusEl.className = 'error';
            es.close();
            setTimeout(connect, 5000);
        };
    }

    connect();
</script>
