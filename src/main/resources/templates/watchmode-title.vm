<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>$title</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            background: #0f0f13;
            color: #e8e8f0;
            min-height: 100vh;
        }

        header {
            background: #18182a;
            border-bottom: 1px solid #2a2a40;
            padding: 14px 24px;
            display: flex;
            align-items: center;
            gap: 14px;
        }

        header a {
            color: #7c6af7;
            text-decoration: none;
            font-size: 0.85rem;
        }
        header a:hover { text-decoration: underline; }

        header h1 {
            font-size: 1.05rem;
            font-weight: 600;
            color: #e8e8f0;
        }

        .container {
            max-width: 780px;
            margin: 28px auto;
            padding: 0 20px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background: #18182a;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 1px 6px rgba(0,0,0,.4);
        }

        tr { border-bottom: 1px solid #242438; }
        tr:last-child { border-bottom: none; }
        tr:hover { background: #1f1f32; }

        td {
            padding: 10px 16px;
            vertical-align: top;
            font-size: 0.85rem;
            line-height: 1.45;
        }

        td:first-child {
            width: 38%;
            color: #888;
            font-weight: 500;
            white-space: nowrap;
        }

        td:last-child {
            color: #d8d8ec;
            word-break: break-word;
        }
    </style>
</head>
<body>

<header>
    <a href="/watchmode">&larr; Back</a>
    <h1>$title</h1>
</header>

<div class="container">
    <table>
#foreach($row in $rows)
        <tr>
            <td>$row[0]</td>
            <td>$!row[1]</td>
        </tr>
#end
    </table>
</div>

</body>
</html>